# 环境变量配置示例
# 复制此文件为 .env 并修改配置

# 是否使用 GPU
USE_GPU=false

# OCR 语言
LANG=ch

# 服务端口
PORT=8868

# 日志级别
LOG_LEVEL=INFO

# CORS 允许的源（逗号分隔）
# 生产环境应设置为具体的域名，如：http://localhost:5173,http://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 最大图片大小（字节，默认10MB）
MAX_IMAGE_SIZE=10485760